# کپی به .env و مقداردهی (در production از فایل امن استفاده کنید)

# PostgreSQL — در Docker Compose: POSTGRES_HOST=db (پیش‌فرض compose)
POSTGRES_DB=balebot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=300

DJANGO_SECRET_KEY=تغییر-بده
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com
DJANGO_TIME_ZONE=Asia/Tehran
DJANGO_LANGUAGE_CODE=fa-ir

# Static / Media — مسیر URL و دیسک (Runflare: /public/static/ و /public/media/)
STATIC_URL=/public/static/
MEDIA_URL=/public/media/
# STATIC_ROOT=/app/public/static
# MEDIA_ROOT=/app/public/media
SERVE_MEDIA=true
SERVE_STATIC=true
SERVE_STATIC_VIA_DJANGO=false
# RUN_COLLECTSTATIC=true

# توکن و وب‌هوک ربات‌ها از پنل (تنظیمات ربات) مدیریت می‌شوند.
# برای مهاجرت از نسخهٔ قدیم، می‌توانید موقت این مقادیر را بگذارید تا در migrate به DB منتقل شوند:
# BALE_BOT_TOKEN=
# BALE_WEBHOOK_SECRET=
# BALE_WEBHOOK_PUBLIC_URL=https://yourdomain.com

CAMPAIGN_SEND_DELAY_MS=80
CAMPAIGN_SEND_BATCH_SIZE=20

# Redis / Celery — سرویس جدا در docker-compose (hostname: redis)
REDIS_URL=redis://redis:6379/0
# REDIS_PASSWORD=          # اختیاری — اگر set شود: REDIS_URL=redis://:PASSWORD@redis:6379/0
# CELERY_BROKER_URL=       # پیش‌فرض: REDIS_URL
# CELERY_RESULT_BACKEND=   # پیش‌فرض: REDIS_URL
WEBHOOK_USE_CELERY=true
CELERY_TASK_ALWAYS_EAGER=false
CELERY_CONCURRENCY=8

# Gunicorn
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30
# WEB_PORT=8000

# لندینگ — اعلان سرنخ و لینک ربات دمو
# LANDING_ADMIN_CHAT_ID=123456789
# LANDING_DEMO_BOT_URL=https://ble.ir/your_demo_bot
