# کپی به .env و مقداردهی (در production از فایل امن استفاده کنید)

# PostgreSQL — قبل از migrate دیتابیس را بسازید، مثلاً:
#   createdb balebot   یا   CREATE DATABASE balebot;
POSTGRES_DB=balebot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# اختیاری: مدت نگه‌داشتن کانکشن‌های باز (ثانیه)، برای workerهای طولانی مثلاً ۶۰
# POSTGRES_CONN_MAX_AGE=0

DJANGO_SECRET_KEY=تغییر-بده
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com
DJANGO_TIME_ZONE=Asia/Tehran
DJANGO_LANGUAGE_CODE=fa-ir

# توکن از @botfather در بله
BALE_BOT_TOKEN=

# باید با مقدار بخش secret در URL وب‌هوک یکی باشد
BALE_WEBHOOK_SECRET=یک-رشته-تصادفی-قوی

# آدرس کامل HTTPS وب‌هوک برای دستور set_bale_webhook (اختیاری)
# مثال: https://yourdomain.com/bale/webhook/همان-m secret/
BALE_WEBHOOK_PUBLIC_URL=

# اختیاری
BALE_API_BASE=https://tapi.bale.ai
CAMPAIGN_SEND_DELAY_MS=80
